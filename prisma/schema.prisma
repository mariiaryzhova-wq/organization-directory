// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum OrganizationStatus {
  pending
  approved
  rejected
  archived
}

model Organization {
  id           Int                @id @default(autoincrement())
  name         String
  description  String?            @db.Text
  websiteUrl   String?            @map("website_url")
  contacts     Json?
  sociaLinks   Json?              @map("social_links")
  workingHours String?            @map("working_hours")
  status       OrganizationStatus @default(pending)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason") @db.Text

  categories OrganizationCategory[]

  locations Location[]

  @@map("organizations")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  organizations OrganizationCategory[]

  @@map("categories")
}

model OrganizationCategory {
  organizationId Int @map("organization_id")
  categoryId     Int @map("category_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([organizationId, categoryId])
  @@map("organization_categories")
}

model Location {
  locationId     Int @id @default(autoincrement()) @map("location_id")
  organizationId Int @map("organization_id")

  street   String?
  city     String
  region   String
  postCode String? @map("post_code")

  latitude  Decimal @db.Decimal(10, 7)
  longitude Decimal @db.Decimal(10, 7)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([region])
  @@index([latitude, longitude])
  @@index([organizationId])
  @@map("locations")
}
